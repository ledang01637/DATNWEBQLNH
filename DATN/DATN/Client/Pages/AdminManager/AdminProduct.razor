@page "/adminproduct"

@using DATN.Shared
@layout LayoutAdmin
@inject HttpClient httpClient
@inject NavigationManager Navigation


<style>
    .product-table-container {
        max-height: 600px;
        overflow-y: auto;
    }

        .product-table-container table {
            width: 100%;
        }

    .search-bar, .filter-bar {
        margin-bottom: 20px;
    }
</style>

@if (isLoaded)
{
    <div class="col-md-12 grid-margin stretch-card p-5">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Product</h4>
                <p class="card-description">
                    <button class="btn btn-success" @onclick="() => CreateProduct()">Add new product</button>
                </p>
                <div class="search-bar">
                    <input type="text" class="form-control" placeholder="Searching product..." @oninput="Filter" />
                </div>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Hình ảnh</th>
                                <th>Tên danh mục</th>
                                <th>Đơn vị</th>
                                <th>Ghi chú</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var prod in filter)
                            {
                                if (prod != null)
                                {
                                    var connectUnit = listUnit.FirstOrDefault(p => p.UnitId == prod.UnitId);

                                    if (connectUnit != null)
                                    {
                                        <tr>
                                            <td>
                                                <img src="data:image/png;base64,@Convert.ToBase64String(prod.ProductImage)" alt="Alternate Text" width="80px" height="80px" />
                                            </td>
                                            <td>@prod.ProductName</td>
                                            <td>@connectUnit.UnitName</td>
                                            <td>@prod.ProductDescripntion</td>
                                            <td class="text-center">
                                                @if (!prod.IsDelete)
                                                {
                                                    <button class="btn btn-primary" @onclick="() => EditProduct(prod.ProductId)">Sửa</button>
                                                    <button class="btn btn-danger" @onclick="() => HideProd(prod.ProductId)">Ẩn</button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-warning" @onclick="() => RestoreProd(prod.ProductId)">Khôi phục</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    <p>Loading...</p>
}

